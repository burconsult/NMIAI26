NMIAI_GAME_TOKEN=replace-me-after-clicking-play
NMIAI_ACCESS_TOKEN=replace-with-access_token-cookie-value
# Optional explicit map id override. Leave empty if you select difficulty in CLI/UI.
NMIAI_MAP_ID=
# Optional override, defaults to https://api.ainm.no/games/request
NMIAI_REQUEST_URL=https://api.ainm.no/games/request
# Optional override, defaults to https://api.ainm.no/games/maps
NMIAI_MAPS_URL=https://api.ainm.no/games/maps
# Local simulator examples:
# NMIAI_REQUEST_URL=http://127.0.0.1:8765/games/request
# NMIAI_MAPS_URL=http://127.0.0.1:8765/games/maps
