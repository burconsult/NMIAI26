{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "functions": {
    "api/*.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/solve",
      "destination": "/api/solve"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ]
}
